# ═══════════════════════════════════════════════════════
# NetraVision AI — .gitignore
# ═══════════════════════════════════════════════════════

# ─── Virtual environments ───
venv/
venv311/
env/
ENV/
.venv/

# ─── Python bytecode & build artifacts ───
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─── Model files (large binaries — download via scripts/download_models.py) ───
*.pt
*.onnx
*.pth
*.bin
models/**/*.pt
models/**/*.onnx
models/**/*.pth
models/**/*.bin
# Keep the JSON config files for piper voices
!models/piper/*.json

# ─── Caches ───
audio_cache/
.cache/
*.cache

# ─── IDE / Editor ───
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS files ───
.DS_Store
Thumbs.db
desktop.ini

# ─── Environment variables (secrets) ───
.env
.env.local
.env.*.local

# ─── Streamlit secrets (NOT config) ───
.streamlit/secrets.toml

# ─── Logs ───
*.log
logs/

# ─── Temporary / scratch files ───
scratch/
transcripts/
*.wav
*.mp3

# ─── Gemini / Agent workspace (local-only) ───
.agent/

# ─── Graphify tool output (regenerable) ───
graphify-out/
