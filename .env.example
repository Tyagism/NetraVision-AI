# ═══════════════════════════════════════════════════════
# NetraVision AI — Environment Configuration
# Copy this file to .env and customize as needed
# ═══════════════════════════════════════════════════════

# Camera settings
CAMERA_INDEX=0
# IP_CAMERA_URL=http://192.168.1.100:8080/video

# TTS settings
TTS_LANGUAGE=en
TTS_SPEED=185
TTS_ENGINE=piper

# Processing settings
DEVICE=auto
SKIP_FRAMES=3

# Model selection
DEPTH_MODEL=small
